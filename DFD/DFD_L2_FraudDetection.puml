@startuml DFD_L2_FraudDetection
title DFD Level 2 – Tiến trình 3.0: Kiểm tra Chống gian lận\n(UC-11: Mock Location/GPS Spoofing + Face Verification,\nUC-12: Buddy Punching)

' ===== Layout & readability =====
left to right direction
skinparam Shadowing false
skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam ArrowColor #2F3B4A
skinparam ArrowThickness 1.1
skinparam ArrowFontSize 10
skinparam nodesep 80
skinparam ranksep 90
hide stereotype

skinparam rectangle {
  BackgroundColor<<external>> LightYellow
  BorderColor<<external>> DarkGoldenRod
}
skinparam rectangle {
  BackgroundColor<<process>> LightSkyBlue
  BorderColor<<process>> Navy
}
skinparam database {
  BackgroundColor LightGreen
  BorderColor DarkGreen
}

rectangle "Tiến trình 2.0\nChấm công" <<external>> as P2
rectangle "Face Verification\nService" <<external>> as FACE

rectangle "3.1\nKiểm tra\nMock Location" <<process>> as P31
rectangle "3.2\nKiểm tra\nGPS Spoofing" <<process>> as P32
rectangle "3.3\nKiểm tra\nBuddy Punching" <<process>> as P33
rectangle "3.4\nXác minh gương mặt\n& Liveness" <<process>> as P34
rectangle "3.5\nTính\nConfidence Score" <<process>> as P35
rectangle "3.6\nLưu kết quả\nFraudDetection" <<process>> as P36

database "D2: Attendance\nRecord (history)" as D2
database "D1: Device\n& Employee Face Template" as D1
database "D3: Fraud\nDetection" as D3
database "D5: Audit Log" as D5

' ===== Position anchors (for cleaner layout) =====
P2 -[hidden]right-> P31
P31 -[hidden]down-> P32
P32 -[hidden]down-> P33
P33 -[hidden]down-> P34

P31 -[hidden]right-> P35
P35 -[hidden]down-> P36

P34 -[hidden]right-> FACE
FACE -[hidden]right-> D1
D1 -[hidden]down-> D2
D2 -[hidden]down-> D3
D3 -[hidden]down-> D5

P2 -right-> P31 : GPS data + raw_signals\n(mock_location flag từ OS)
P31 --> P31 : Đọc cờ mock location\ntừ hệ điều hành thiết bị
P31 -right-> P35 : mock_location_detected (bool)

P2 -right-> P32 : lat, lng, altitude,\ngps_accuracy, employee_id
P32 -right-> D2 : SELECT 3 vị trí gần nhất\ncủa employee_id
D2 -left-> P32 : lịch sử tọa độ
P32 --> P32 : Tính speed = distance/time\nKiểm tra altitude bất thường\nKiểm tra accuracy âm
P32 -right-> P35 : gps_spoofing_detected (bool)

P2 -right-> P33 : device_fingerprint,\nemployee_id, lat, lng, timestamp
P33 -right-> D1 : SELECT Device WHERE fingerprint=?
D1 -left-> P33 : device + is_trusted
P33 -right-> D2 : SELECT check-in gần nhất\ncùng device_fingerprint\n(employee_id khác)
D2 -left-> P33 : danh sách sử dụng thiết bị
P33 --> P33 : Phân tích impossible travel\n(speed > 200 km/h)
P33 -right-> P35 : buddy_punch_suspected (bool)\nunknown_device (bool)

' Face verification flow
P2 -right-> P34 : employee_id, face_image,\nliveness_signals
P34 -right-> D1 : SELECT face_template\nWHERE employee_id=?
D1 -left-> P34 : face_template (encrypted)
P34 -right-> FACE : verifyFace(face_image,\nface_template, liveness_signals)
FACE -left-> P34 : face_match_score,\nliveness_score,\nface_matched,\nliveness_passed
P34 -right-> P35 : face_mismatch_detected,\nliveness_failed

P35 --> P35 : Tính confidence_score
note right of P35
score = 100
- mock_location: -50
- gps_spoofing: -40
- unknown_device: -20
- face_mismatch: -45
- liveness_failed: -60
(min = 0)
end note
P35 -down-> P36 : FraudResult {flags, scores,\nconfidence_score, raw_signals}

P36 -right-> D3 : INSERT FraudDetection
P36 -right-> D5 : INSERT AuditLog\n(nếu có cảnh báo)
P36 -left-> P2 : FraudResult (để quyết định approve/reject)

@enduml
