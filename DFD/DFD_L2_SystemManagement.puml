@startuml DFD_L2_SystemManagement
title DFD Level 2 – Tiến trình 5.0: Quản lý Hệ thống\n(UC-08: Shift, UC-10: Ngoại lệ,\nUC-13: Thiết bị, UC-14: Audit Log, UC-15: Nhân viên)

' ===== Layout & readability =====
left to right direction
skinparam Shadowing false
skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam ArrowColor #2F3B4A
skinparam ArrowThickness 1.1
skinparam ArrowFontSize 11
skinparam nodesep 130
skinparam ranksep 150
hide stereotype

skinparam rectangle {
  BackgroundColor<<external>> LightYellow
  BorderColor<<external>> DarkGoldenRod
}
skinparam rectangle {
  BackgroundColor<<process>> LightSkyBlue
  BorderColor<<process>> Navy
}
skinparam database {
  BackgroundColor LightGreen
  BorderColor DarkGreen
}

rectangle "Admin / HR" <<external>> as Admin

rectangle "5.1\nQuản lý\nNhân viên & Phòng ban" <<process>> as P51
rectangle "5.2\nQuản lý\nCa làm việc" <<process>> as P52
rectangle "5.3\nQuản lý\nNgoại lệ chấm công" <<process>> as P53
rectangle "5.4\nQuản lý\nThiết bị tin cậy" <<process>> as P54
rectangle "5.5\nTra cứu\nAudit Log" <<process>> as P55

database "D1: Employee\nAccount & Device" as D1
database "D2: Attendance\nRecord" as D2
database "D3: Fraud\nDetection" as D3
database "D5: Audit Log" as D5
database "D6: Shift\n& Department" as D6

' ===== Position anchors (for cleaner layout) =====
Admin -[hidden]right-> P51
P52 -[hidden]down-> P51
P51 -[hidden]down-> P54
P54 -[hidden]down-> P53
P53 -[hidden]down-> P55

P52 -[hidden]right-> D6
P51 -[hidden]right-> D1
P54 -[hidden]right-> D5
P53 -[hidden]right-> D2
P55 -[hidden]right-> D3

D6 -[hidden]down-> D1
D1 -[hidden]down-> D5
D5 -[hidden]down-> D2
D2 -[hidden]down-> D3

' UC-15: Employee management
Admin -right-> P51 : thông tin nhân viên\n(full_name, dept, role, email)
P51 -right-> D1 : INSERT/UPDATE Employee, Account\n(status, is_active)
P51 -up-> D6 : INSERT/UPDATE Department
P51 -right-> D5 : AuditLog
P51 -left-> Admin : xác nhận tạo/cập nhật

' UC-08: Shift management
Admin -right-> P52 : cấu hình ca\n(name, start_time, end_time,\ntolerance, apply_to_weekends)
P52 --> P52 : kiểm tra xung đột giờ
P52 -right-> D6 : INSERT/UPDATE Shift
P52 -right-> D1 : UPDATE Employee.default_shift_id\n(gán ca cho nhân viên)
P52 -right-> D5 : AuditLog
P52 -left-> Admin : xác nhận

' UC-10: Exception management
Admin -right-> P53 : yêu cầu xem ngoại lệ
P53 -right-> D2 : SELECT AttendanceRecord\nWHERE status=rejected OR is_late OR is_early_leave
D2 -left-> P53 : danh sách ngoại lệ
P53 -right-> D3 : SELECT FraudDetection (chi tiết)
D3 -left-> P53 : fraud flags
P53 -left-> Admin : danh sách ngoại lệ + chi tiết

Admin -right-> P53 : quyết định phê duyệt thủ công
P53 -right-> D2 : UPDATE AttendanceRecord.status='approved'
P53 -up-> D5 : AuditLog (MANUAL_APPROVE)

' UC-13: Device management
Admin -right-> P54 : cập nhật is_trusted
P54 -up-> D1 : UPDATE Device.is_trusted
P54 -right-> D5 : AuditLog (DEVICE_TRUST / DEVICE_UNTRUST)
P54 -left-> Admin : xác nhận

' UC-14: Audit log search
Admin -right-> P55 : bộ lọc (actor, action_type, time range)
P55 -up-> D5 : SELECT AuditLog WHERE điều kiện
D5 -down-> P55 : log entries
P55 -left-> Admin : danh sách log (read-only)

@enduml
