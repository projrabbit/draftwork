erDiagram
    BUILDING ||--o{ FLOOR : contains
    FLOOR ||--o{ CELL_SPACE : contains
    CELL_SPACE ||--o{ CELL_SPACE_BOUNDARY : has
    CELL_SPACE ||--o{ STATE : represented_by
    STATE ||--o{ TRANSITION : from_state
    STATE ||--o{ TRANSITION : to_state
    CELL_SPACE ||--o{ GEOFENCE_RULE : has
    CELL_SPACE ||--o{ GIS_LAYER : displayed_by

    BUILDING {
        INT building_id PK
        STRING name
        STRING address
        DECIMAL center_lat
        DECIMAL center_lng
        INT total_floors
        STRING arcgis_layer_id
    }

    FLOOR {
        INT floor_id PK
        INT building_id FK
        INT floor_number
        STRING floor_name
        DECIMAL altitude_min
        DECIMAL altitude_max
    }

    CELL_SPACE {
        INT cell_space_id PK
        INT floor_id FK
        STRING name
        STRING space_type
        STRING geometry_ref
        DECIMAL altitude_min
        DECIMAL altitude_max
        BOOLEAN is_work_area
        BOOLEAN is_active
    }

    CELL_SPACE_BOUNDARY {
        INT boundary_id PK
        INT cell_space_id FK
        STRING boundary_type
        STRING boundary_geometry_ref
        STRING description
    }

    STATE {
        INT state_id PK
        INT cell_space_id FK
        DECIMAL latitude
        DECIMAL longitude
        DECIMAL altitude
        STRING state_type
    }

    TRANSITION {
        INT transition_id PK
        INT from_state_id FK
        INT to_state_id FK
        STRING transition_type
        DECIMAL distance_m
    }

    GEOFENCE_RULE {
        INT geofence_rule_id PK
        INT cell_space_id FK
        DECIMAL allowed_radius_m
        DECIMAL altitude_min
        DECIMAL altitude_max
        BOOLEAN allow_checkin
        BOOLEAN allow_checkout
        BOOLEAN is_active
        INT created_by_account_id FK
    }

    GIS_LAYER {
        INT layer_id PK
        INT cell_space_id FK
        STRING arcgis_layer_id
        STRING layer_type
        STRING layer_url
        BOOLEAN is_visible
    }
