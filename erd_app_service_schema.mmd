erDiagram
    DEPARTMENT ||--o{ EMPLOYEE : has
    EMPLOYEE ||--|| ACCOUNT : owns
    EMPLOYEE ||--o{ DEVICE : registers
    EMPLOYEE ||--o{ ATTENDANCE_RECORD : creates
    DEVICE ||--o{ ATTENDANCE_RECORD : used_for
    SHIFT ||--o{ ATTENDANCE_RECORD : applies_to
    ATTENDANCE_RECORD ||--|| FRAUD_DETECTION : checked_by
    ACCOUNT ||--o{ AUDIT_LOG : writes
    SHIFT ||--o{ SHIFT_ASSIGNMENT : assigned_by
    DEPARTMENT ||--o{ SHIFT_ASSIGNMENT : department_scope
    EMPLOYEE ||--o{ SHIFT_ASSIGNMENT : employee_scope

    DEPARTMENT {
        INT department_id PK
        STRING name
        STRING description
        INT manager_id FK
        DATETIME created_at
    }

    EMPLOYEE {
        INT employee_id PK
        STRING full_name
        INT department_id FK
        STRING position
        STRING email
        STRING phone
        DATE hire_date
        STRING status
    }

    ACCOUNT {
        INT account_id PK
        INT employee_id FK
        STRING username
        STRING password_hash
        STRING role
        DATETIME last_login_at
        BOOLEAN is_active
    }

    DEVICE {
        INT device_id PK
        INT employee_id FK
        STRING device_fingerprint
        STRING platform
        STRING model
        DATETIME registered_at
        BOOLEAN is_trusted
    }

    SHIFT {
        INT shift_id PK
        STRING name
        TIME start_time
        TIME end_time
        INT late_tolerance_min
        INT early_leave_min
        BOOLEAN apply_to_weekends
    }

    SHIFT_ASSIGNMENT {
        INT assignment_id PK
        INT shift_id FK
        INT employee_id FK
        INT department_id FK
        DATE effective_from
        DATE effective_to
        INT assigned_by_account_id FK
    }

    ATTENDANCE_RECORD {
        BIGINT record_id PK
        INT employee_id FK
        INT device_id FK
        INT shift_id FK
        INT geofence_rule_id FK
        STRING type
        DATETIME timestamp
        DECIMAL latitude
        DECIMAL longitude
        DECIMAL altitude
        DECIMAL gps_accuracy
        STRING status
        STRING rejection_reason
        BOOLEAN is_late
        BOOLEAN is_early_leave
    }

    FRAUD_DETECTION {
        BIGINT fraud_id PK
        BIGINT record_id FK
        BOOLEAN mock_location_detected
        BOOLEAN gps_spoofing_detected
        BOOLEAN buddy_punch_suspected
        BOOLEAN unknown_device
        DECIMAL confidence_score
        JSON raw_signals
        DATETIME checked_at
    }

    AUDIT_LOG {
        BIGINT log_id PK
        INT actor_account_id FK
        STRING action_type
        STRING target_entity
        BIGINT target_id
        JSON payload
        STRING ip_address
        DATETIME created_at
    }
